# ═══════════════════════════════════════════════════════
# DJANGO
# ═══════════════════════════════════════════════════════
SECRET_KEY=django-insecure-change-this-in-production-xyz123
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,.ngrok-free.dev,.ngrok.io

# ═══════════════════════════════════════════════════════
# BASE DE DATOS (Desarrollo: PostgreSQL Local)
# ═══════════════════════════════════════════════════════
DATABASE_URL=postgresql://fran_user:fran_password@db:5432/fran_bot_db

# ═══════════════════════════════════════════════════════
# CELERY & REDIS
# ═══════════════════════════════════════════════════════
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ═══════════════════════════════════════════════════════
# GOOGLE GEMINI (OBLIGATORIO)
# ═══════════════════════════════════════════════════════
GOOGLE_API_KEY=

# Obtener en: https://makersuite.google.com/app/apikey

# ═══════════════════════════════════════════════════════
# NGROK (Para Webhooks en Desarrollo) ⭐ NUEVO
# ═══════════════════════════════════════════════════════
NGROK_AUTHTOKEN=

# Obtener gratis en: https://dashboard.ngrok.com/get-started/your-authtoken
# Pasos:
# 1. Crear cuenta en https://ngrok.com
# 2. Copiar tu authtoken
# 3. Pegar aquí

# ═══════════════════════════════════════════════════════
# TELEGRAM (Desarrollo)
# ═══════════════════════════════════════════════════════
USE_TELEGRAM=true
TELEGRAM_BOT_TOKEN=

# Obtener con: python scripts/setup_telegram_bot.py

# ═══════════════════════════════════════════════════════
# WHATSAPP BUSINESS API (Producción)
# ═══════════════════════════════════════════════════════
USE_WHATSAPP=false
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=fran_bot_webhook_secret_2025

# ═══════════════════════════════════════════════════════
# GMAIL API (Producción - Solo Drafts)
# ═══════════════════════════════════════════════════════
USE_GMAIL=false
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REFRESH_TOKEN=

# ═══════════════════════════════════════════════════════
# TRELLO
# ═══════════════════════════════════════════════════════
TRELLO_API_KEY=
TRELLO_TOKEN=
TRELLO_BOARD_ID=
TRELLO_LIST_ID=

# ═══════════════════════════════════════════════════════
# SUPABASE (Producción)
# ═══════════════════════════════════════════════════════
USE_SUPABASE=false
SUPABASE_URL=
SUPABASE_KEY=
SUPABASE_BUCKET=fran-bot-media

# ═══════════════════════════════════════════════════════
# CONFIGURACIÓN REGIONAL
# ═══════════════════════════════════════════════════════
TIME_ZONE=America/Lima
LANGUAGE_CODE=es-ar